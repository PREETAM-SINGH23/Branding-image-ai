# Copy to ".env" in this directory (backend/) and adjust values.
# Loaded automatically on startup via python-dotenv.

# App / creative job logging (INFO shows per-file render lines in the console)
# LOG_LEVEL=INFO

# --- Auth ---
# Generate a strong secret for production, e.g. openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# JWT lifetime in minutes (default 1440 = 24h)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# Default: SQLite file under ./data/app.db (absolute path recommended in production)
# DATABASE_URL=sqlite:////absolute/path/to/app.db

# --- Storage ---
# UPLOAD_DIR=/absolute/path/to/uploads
# OUTPUT_DIR=/absolute/path/to/outputs

# --- AI hero (OpenAI Images API, e.g. dall-e-3) ---
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_IMAGE_MODEL=dall-e-3
